import {Shape} from 'lincd/shapes/Shape';
import {NamedNode} from 'lincd/models';
import {linkedShape} from '../package.js';
import { org } from '../ontologies/org.js';
import { Membership } from './Membership.js';

//NOTE, org:Orgnization class is a subclass of foaf:Agent. Extend lincd-foaf/shapes/Agent shape?

@linkedShape
export class Organization extends Shape {
  static targetClass:NamedNode = org.Organization;

  get memberships() {
    return this.getAllAs<Membership>(org.hasMembership, Membership);
  }

}
